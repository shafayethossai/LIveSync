# Application Configuration
VERSION=1.0.0
HTTPPORT=4000
SERVICENAME=livesync-backend
SECRETKEY=your-secret-key-change-in-production

# Database Configuration (use either DB_STRING or individual DB variables)
# Option 1: Individual database variables (for local PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=livesync_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_ENABLE_SSL_MODE=false

# Option 2: Connection string (for Neon PostgreSQL or cloud databases)
# Uncomment and use this if using a managed database service
DB_STRING=postgresql://user:password@host:port/dbname?sslmode=require

# Google OAuth Configuration (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URL=https://yourdomain.com/api/auth/google/callback

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=noreply@yourdomain.com

# For Render deployment, set these in Render's Environment Variables:
# Dashboard -> Select Service -> Settings -> Environment -> Add Environment Variables
